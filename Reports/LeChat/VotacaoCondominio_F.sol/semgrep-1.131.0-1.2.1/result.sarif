                                }
                            }
                        }
                    ],
                    "message": {
                        "text": "Uninitialized variables are assigned with the types default value. Explicitly initializing a variable with its default value costs unnecessary gas."
                    },
                    "ruleId": "semgrep_1_131_0_1_2_1_init_variables_with_default_value"
